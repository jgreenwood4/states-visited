# Copy to ".env" and adjust. None of these are required for local development —
# the app falls back to a local SQLite file and port 5000 when they're unset.

# PostgreSQL connection string (production). When unset, a local SQLite file is
# used instead, so you don't need Postgres installed to develop locally.
# DATABASE_URL=postgresql://user:password@localhost:5432/fifty

# Secret used to sign the login session cookie. Set a long random value in prod.
# SECRET_KEY=change-me-to-something-random

# Port the server listens on (defaults to 5000).
# PORT=5000
